#!/usr/bin/env bash
# Stop hook: mechanical handoff enforcement in project repos.
#
# The SessionStart gate makes models *start* the lifecycle; this closes the
# other end — sessions that finish work but never persist it. Two checks,
# cheapest signal first, each self-limiting so it never nags every turn:
#
#   A. The response just issued the three-field SDLC report -> verify the
#      claim: run check-state.sh --strict; any FAIL blocks with the FAIL lines.
#   B. The tree has been dirty for >45 min since the last reminder -> gentle
#      nudge (armed at the first stop, so a pre-existing dirty tree does not
#      nag on turn 1).
#
# Blocking uses exit 2 + stderr (fed back to the model). `stop_hook_active`
# short-circuits so a blocked stop never re-blocks its own continuation.
# Transcript inspection (A) needs jq; without jq only B runs. Emits
# nothing and exits 0 outside git repos.

set -uo pipefail

[ "${AI_SDLC_SCRATCH:-}" = "1" ] && exit 0
input=$(cat 2>/dev/null || true)

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0
printf '%s' "$input" | grep -Eq '"stop_hook_active"[[:space:]]*:[[:space:]]*true' && exit 0

json_str() {
  printf '%s' "$input" \
    | sed -nE 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/p' | head -1
}

session_id=$(json_str session_id)
[ -n "$session_id" ] || session_id=unknown
transcript=$(json_str transcript_path)
marker="${TMPDIR:-/tmp}/sdlc-handoff-gate-${session_id}"

dirty() { [ -n "$(git status --porcelain 2>/dev/null)" ]; }

block() {
  printf '%s\n' "$1" >&2
  touch "$marker" 2>/dev/null || true
  exit 2
}

# Final text message of the turn (last assistant entry that has a text block).
last_text=""
if command -v jq >/dev/null 2>&1 && [ -n "$transcript" ] && [ -f "$transcript" ]; then
  last_text=$(jq -rs '
    def assistant_content:
      if .type == "assistant" then
        (.message.content // [])
      elif .type == "response_item"
        and .payload.type == "message"
        and .payload.role == "assistant" then
        (.payload.content // [])
      else
        empty
      end;
    [ .[]
      | assistant_content
      | (if type == "array" then . else [] end)
      | map(select((.type == "text" or .type == "output_text") and (.text | type == "string")) | .text)
      | join("\n")
      | select(length > 0)
    ] | last // ""' "$transcript" 2>/dev/null || true)
fi

# A — the exact three-field report is a checkable claim; check it.
if printf '%s\n' "$last_text" | grep -q '^What changed:' \
  && printf '%s\n' "$last_text" | grep -q '^What was verified:' \
  && printf '%s\n' "$last_text" | grep -q '^Remaining risk:'; then
  check=""
  for c in "$HOME/.agents/skills/sdlc-core/scripts/check-state.sh" \
           "$HOME/.claude/skills/sdlc-core/scripts/check-state.sh"; do
    [ -f "$c" ] && { check="$c"; break; }
  done
  if [ ! -d .ai-sdlc ]; then
    block "sdlc gate: the SDLC report was issued but .ai-sdlc/ does not exist — nothing was persisted. Run Skill(sdlc-finish) for real: scaffold state.md, append the journal entry, then re-issue the report."
  fi
  if [ -n "$check" ]; then
    out=$(bash "$check" --strict . 2>&1) || block "sdlc gate: the SDLC report was issued but the artifacts fail STATE-SPEC:
$out
Fix every FAIL line, re-run check-state.sh --strict until it prints 'check-state: OK', then re-issue the report."
  fi
  touch "$marker" 2>/dev/null || true
  exit 0
fi

# B — throttled dirty-tree reminder: arm on first stop, nag at most per 45 min.
if [ ! -f "$marker" ]; then
  touch "$marker" 2>/dev/null || true
  exit 0
fi
if dirty && [ -n "$(find "$marker" -mmin +45 2>/dev/null)" ]; then
  block "sdlc gate: the working tree has had uncommitted changes for over 45 minutes. If this session is wrapping up, invoke Skill(sdlc-finish); otherwise continue — this reminder repeats roughly every 45 minutes while changes sit uncommitted."
fi

exit 0
