{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/sdlc-lifecycle-gate",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hook=\"$HOME/.claude/hooks/sdlc-handoff-gate\"; [ -x \"$hook\" ] || hook=\"$CLAUDE_PLUGIN_ROOT/hooks/sdlc-handoff-gate\"; exec \"$hook\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
